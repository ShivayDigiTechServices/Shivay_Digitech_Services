            document.getElementById('instruction-portal').classList.add('hidden');
            document.getElementById('exam-dashboard').classList.remove('hidden');
            document.getElementById('exam-footer').classList.remove('hidden');
            
            document.getElementById('display-candidate-name').innerText = candidateName;
            document.getElementById('display-attempt-count').innerText = `Attempt: ${attemptCount}`;
            document.getElementById('exam-attempt-title').innerText = `HPRCA Computer Practice Mock Test 2026 (Attempt #${attemptCount})`;

            buildGridPalette();
            loadQuestion();
            startCountdownTimer();
        }

        function buildGridPalette() {
            const grid = document.getElementById("question-grid");
            grid.innerHTML = "";
            for (let i = 1; i <= 100; i++) {
                const item = document.createElement("div");
                item.className = "grid-item status-unvisited";
                item.innerText = i;
                item.id = "grid-q-" + i;
                
                if(i <= quizQuestions.length) {
                    item.addEventListener("click", () => jumpToQuestion(i - 1));
                }
                grid.appendChild(item);
            }
            updateGridVisuals();
        }

        function jumpToQuestion(idx) {
            if(studentAnswers[currentIdx] === null && questionStatuses[currentIdx] !== 'review') {
                questionStatuses[currentIdx] = 'unanswered';
            }
            currentIdx = idx;
            loadQuestion();
        }

        function changeActiveLanguage(langVal) {
            currentLang = langVal;
            loadQuestion();
        }

        function loadQuestion() {
            selectedOption = studentAnswers[currentIdx];
            const q = quizQuestions[currentIdx];
            const container = document.getElementById('question-render');
            
            let showEnglish = (currentLang === 'bilingual' || currentLang === 'english');
            let showHindi = (currentLang === 'bilingual' || currentLang === 'hindi');

            let html = `<div class="q-text-section">`;
            
            if(showEnglish) {
                html += `
                    <div class="lang-text english">
                        <span class="q-num-badge">Question ${currentIdx + 1}</span>
                        <strong>${q.qE.replace(/\n/g, '<br>')}</strong>
                    </div>
                `;
            }
            if(showHindi) {
                html += `
                    <div class="lang-text hindi">
                        ${!showEnglish ? `<span class="q-num-badge">प्रश्न ${currentIdx + 1}</span>` : ''}
                        <strong>${q.qH.replace(/\n/g, '<br>')}</strong>
                    </div>
                `;
            }

            html += `</div><div class="options-group">`;

            q.options.forEach((opt, index) => {
                let isChecked = (selectedOption === index) ? "checked" : "";
                html += `
                    <label class="option-label" onclick="selectOpt(${index})">
                        <input type="radio" name="q-ans" id="opt-${index}" value="${index}" ${isChecked}>
                        <span>${opt}</span>
                    </label>
                `;
            });

            html += `</div>`;
            container.innerHTML = html;

            document.querySelectorAll('.grid-item').forEach(el => el.classList.remove('active'));
            const activeGridItem = document.getElementById("grid-q-" + (currentIdx + 1));
            if(activeGridItem) activeGridItem.classList.add('active');

            if(currentIdx === quizQuestions.length - 1) {
                document.getElementById('next-btn').innerText = "Submit Exam";
            } else {
                document.getElementById('next-btn').innerText = "Save & Next";
            }
        }

        function selectOpt(index) {
            selectedOption = index;
            studentAnswers[currentIdx] = index;
            document.getElementById(`opt-${index}`).checked = true;
        }

        function clearAnswer() {
            selectedOption = null;
            studentAnswers[currentIdx] = null;
            document.querySelectorAll('input[name="q-ans"]').forEach(el => el.checked = false);
            questionStatuses[currentIdx] = 'unanswered';
            updateGridVisuals();
        }

        function markForReview() {
            questionStatuses[currentIdx] = 'review';
            updateGridVisuals();
            proceedNext();
        }

        function saveAndNext() {
            if(selectedOption !== null) {
                questionStatuses[currentIdx] = 'saved';
            } else {
                questionStatuses[currentIdx] = 'unanswered';
            }
            updateGridVisuals();
            proceedNext();
        }

        function proceedNext() {
            if(currentIdx < quizQuestions.length - 1) {
                currentIdx++;
                loadQuestion();
            } else {
                let conf = confirm("Are you sure you want to submit the exam? Final submission requests feedback survey.");
                if(conf) {
                    initiateFeedbackPortal();
                }
            }
        }

        function updateGridVisuals() {
            for (let i = 0; i < quizQuestions.length; i++) {
                const item = document.getElementById("grid-q-" + (i + 1));
                if(item) {
                    item.className = "grid-item";
                    if(questionStatuses[i] === 'saved') {
                        item.classList.add('status-saved');
                    } else if(questionStatuses[i] === 'unanswered') {
                        item.classList.add('status-unanswered');
                    } else if(questionStatuses[i] === 'review') {
                        item.classList.add('status-review');
                    } else {
                        item.classList.add('status-unvisited');
                    }
                }
            }
        }

        function startCountdownTimer() {
            timerMin = 45;
            timerSec = 0;
            clearInterval(timerInterval);
            timerInterval = setInterval(() => {
                if(timerSec === 0) {
                    if(timerMin === 0) {
                        clearInterval(timerInterval);
                        alert("Time limit reached!");
                        initiateFeedbackPortal();
                        return;
                    }
                    timerMin--;
                    timerSec = 59;
                } else {
                    timerSec--;
                }
                document.getElementById('time-left').innerText = `⏳ Time Left: ${timerMin}:${timerSec < 10 ? '0' : ''}${timerSec}`;
            }, 1000);
        }

        function initiateFeedbackPortal() {
            clearInterval(timerInterval);
            document.getElementById('exam-dashboard').classList.add('hidden');
            document.getElementById('exam-footer').classList.add('hidden');
            document.getElementById('review-feedback-portal').classList.remove('hidden');
        }

        function submitFeedbackForm() {
            const radioVal = document.querySelector('input[name="next_exam_suggest"]:checked').value;
            const textVal = document.getElementById('custom-review-txt').value.trim();

            document.getElementById('hidden-review-target').value = radioVal;
            document.getElementById('hidden-custom-review').value = textVal;

            document.getElementById('review-feedback-portal').classList.add('hidden');
            showFinalResults();
        }

        function showFinalResults() {
            document.getElementById('result-panel').classList.remove('hidden');

            let answeredCount = 0;
            let unattemptedCount = 0;
            let correctCount = 0;
            let incorrectCount = 0;

            studentAnswers.forEach((ans, index) => {
                if(ans !== null) {
                    answeredCount++;
                    if(ans === quizQuestions[index].correct) {
                        correctCount++;
                    } else {
                        incorrectCount++;
                    }
                } else {
                    unattemptedCount++;
                }
            });

            const finalScore = correctCount;
            const accuracyRate = answeredCount > 0 ? Math.round((correctCount / answeredCount) * 100) : 0;
            const passingStatus = (finalScore >= quizQuestions.length * 0.4) ? "QUALIFIED (सफल)" : "NEEDS PRACTICE (अभ्यास की आवश्यकता)";

            document.getElementById('dash-candidate-header').innerText = `Performance Scorecard - ${candidateName}`;
            document.getElementById('stats-total-q').innerText = quizQuestions.length;
            document.getElementById('stats-attempted').innerText = answeredCount;
            document.getElementById('stats-unattempted').innerText = unattemptedCount;
            document.getElementById('stats-correct').innerText = correctCount;
            document.getElementById('stats-incorrect').innerText = incorrectCount;
            document.getElementById('stats-net-score').innerText = `${finalScore} / ${quizQuestions.length}`;
            
            document.getElementById('accuracy-percentage').innerText = `${accuracyRate}%`;
            document.getElementById('accuracy-progress').style.width = `${accuracyRate}%`;

            document.getElementById('detailed-attempt-lbl').innerText = attemptCount;
            document.getElementById('detailed-status-lbl').innerText = passingStatus;

            const randQuote = quotes[Math.floor(Math.random() * quotes.length)];
            document.getElementById('quote-container').innerText = `"${randQuote}"`;

            buildSolutionExplanations();

            document.getElementById('hidden-score').value = `${finalScore} out of ${quizQuestions.length} (Correct: ${correctCount}, Incorrect: ${incorrectCount})`;
            document.getElementById('hidden-feedback').value = `Accuracy: ${accuracyRate}% | Status: ${passingStatus}`;
            document.getElementById('hidden-attempt').value = `Attempt Number: ${attemptCount}`;

            const form = document.getElementById('portalForm');
            const formData = new FormData(form);

            fetch(form.action, {
                method: "POST",
                body: formData,
                headers: {
                    'Accept': 'application/json'
                }
            }).then(() => {
                console.log("CBT performance feedback recorded successfully.");
            }).catch(err => {
                console.error("Submission failed: ", err);
            });
        }

        function toggleSolutionSection() {
            const solDiv = document.getElementById('solution-wrapper-sec');
            solDiv.classList.toggle('hidden');
        }

        function buildSolutionExplanations() {
            const renderer = document.getElementById('solutions-renderer');
            renderer.innerHTML = "";

            quizQuestions.forEach((q, index) => {
                const userAnsIdx = studentAnswers[index];
                const isCorrect = (userAnsIdx === q.correct);
                const userAnsText = userAnsIdx !== null ? q.options[userAnsIdx] : "Not Attempted (प्रयास नहीं किया)";
                const correctAnsText = q.options[q.correct];

                const item = document.createElement('div');
                item.className = "sol-item";
                item.innerHTML = `
                    <strong>Q${index + 1}. ${q.qE}</strong><br>
                    <span style="color:#1a5276; font-size:13px; font-weight:500;">प्र. ${q.qH}</span>
                    <div class="sol-text-correct">✔️ Correct Answer: ${correctAnsText}</div>
                    <div class="sol-text-user" style="color: ${isCorrect ? 'var(--green-saved)' : 'var(--red-unanswered)'}">
                        👤 Your Selected Option: ${userAnsText} ${isCorrect ? ' (Correct)' : ' (Wrong)'}
                    </div>
                `;
                renderer.appendChild(item);
            });
        }

        function restartExamForMultipleAttempt() {
            attemptCount++;
            currentIdx = 0;
            selectedOption = null;
            
            studentAnswers = new Array(quizQuestions.length).fill(null);
            questionStatuses = new Array(quizQuestions.length).fill('unvisited');

            document.getElementById('result-panel').classList.add('hidden');
            document.getElementById('solution-wrapper-sec').classList.add('hidden');
            document.getElementById('instruction-portal').classList.remove('hidden');
        }
    </script>
</body>
</html>
